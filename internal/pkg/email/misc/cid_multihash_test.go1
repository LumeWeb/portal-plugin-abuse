package misc

import (
	"crypto/sha256"
	"testing"

	"github.com/mnako/letters"
	"github.com/mr-tron/base58"
	mh "github.com/multiformats/go-multihash"
	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
	coreTesting "go.lumeweb.com/portal/core/testing"
)

// TestGenerateMultihashExamples generates various types of CID/multihash values
// to help the test suite have valid real-world examples
func TestGenerateMultihashExamples(t *testing.T) {
	// Sample data to hash
	testData := []byte("lume portal-plugin-abuse test data")
	testData2 := []byte("another unique test string for different hashes")

	// Store generated hashes
	hashes := make(map[string]string)

	// Raw SHA-256 hash (hex format)
	rawHash := sha256.Sum256(testData)
	hexHash := rawHash[:]

	// Simple CIDv0 (SHA-256, base58)
	cidv0, err := mh.Sum(testData, mh.SHA2_256, -1)
	require.NoError(t, err)
	hashes["cidv0"] = "Qm" + base58.Encode(cidv0[2:])

	// Generate various types of multihashes
	hashTypes := map[string]uint64{
		"sha2-256":    mh.SHA2_256,
		"sha2-512":    mh.SHA2_512,
		"sha3-256":    mh.SHA3_256,
		"sha3-512":    mh.SHA3_512,
		"blake2b-256": mh.BLAKE2B_MIN + 32 - 1,
		"blake2b-512": mh.BLAKE2B_MIN + 64 - 1,
		"blake3":      mh.BLAKE3,
	}

	for name, code := range hashTypes {
		h, err := mh.Sum(testData, code, -1)
		require.NoError(t, err)
		hashes[name] = base58.Encode(h)

		// Generate a second example with different data
		h2, err := mh.Sum(testData2, code, -1)
		require.NoError(t, err)
		hashes[name+"-2"] = base58.Encode(h2)
	}

	// Print out the hashes so we can use them in content extractor tests
	t.Log("Generated multihash examples for testing:")
	t.Log("Raw hex SHA-256:", hexHash)

	for name, hash := range hashes {
		t.Logf("%s: %s (len: %d)", name, hash, len(hash))
	}

	// Test our regex against the generated hashes
	// Create a ContentExtractor with the updated regex
	testCtx := coreTesting.NewTestContext(t)
	defer testCtx.Teardown()

	logger := testCtx.Logger()
	extractor := NewContentExtractor(logger)

	// Construct an email with all our hashes
	emailText := "Testing multihash detection:\n"
	for name, hash := range hashes {
		emailText += name + ": " + hash + "\n"
	}

	// Add the hex hash
	emailText += "Raw hex hash: " + string(hexHash) + "\n"

	// Make a slice of expected hash values
	var expectedHashes []string
	for _, hash := range hashes {
		expectedHashes = append(expectedHashes, hash)
	}

	// Extract hashes and verify
	email := createTestEmail(emailText, "")
	extractedHashes := extractor.ExtractHashes(email)

	// Print out what was found vs expected
	t.Log("Expected hashes:", expectedHashes)
	t.Log("Extracted hashes:", extractedHashes)
	
	// Test that our regex is matching the hashes correctly
	for _, hash := range expectedHashes {
		assert.Contains(t, extractedHashes, hash, "Extractor should detect hash: "+hash)
	}
}

// Helper function to create a test email
func createTestEmail(text, html string) *letters.Email {
	return &letters.Email{
		Text: text,
		HTML: html,
	}
}
