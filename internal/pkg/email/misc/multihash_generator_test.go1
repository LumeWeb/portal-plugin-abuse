//go:build manual
// +build manual

package misc

import (
	"bytes"
	"crypto/sha256"
	"encoding/base32"
	"encoding/base64"
	"encoding/binary"
	"encoding/hex"
	"fmt"
	"testing"

	"github.com/mr-tron/base58"
	mh "github.com/multiformats/go-multihash"
	"lukechampine.com/blake3"
)

// TestGenerateMultihashExamples generates various CID/multihash types to use in tests
// Run this test manually with:
// go test -tags=manual ./internal/pkg/email/multihash_generator_test.go -v
func TestGenerateMultihashExamples(t *testing.T) {
	testData := []byte("lume portal-plugin-abuse test data")

	fmt.Printf("\n=== IPLD CID/Multihash Examples ===\n\n")
	fmt.Printf("Input data: %q\n\n", testData)

	// Generate different hash types
	hashTypes := map[string]uint64{
		"sha1":     mh.SHA1,
		"sha2-256": mh.SHA2_256,
		"sha2-512": mh.SHA2_512,
		"sha3-256": mh.SHA3_256,
		"sha3-512": mh.SHA3_512,
		"blake3":   mh.BLAKE3,
	}

	// Process each hash type
	for name, code := range hashTypes {
		// Generate the multihash
		h, err := mh.Sum(testData, code, -1)
		if err != nil {
			t.Fatalf("Error generating %s hash: %v", name, err)
		}

		// Print hash details
		fmt.Printf("Hash type: %s (code: 0x%x)\n", name, code)
		fmt.Printf("  Raw bytes: %s\n", hex.EncodeToString(h))
		fmt.Printf("  Base58: %s\n", mh.Multihash(h).B58String())
		fmt.Printf("  String: %s\n", mh.Multihash(h).String())

		// Get decoded details for verification
		decoded, err := mh.Decode(h)
		if err != nil {
			t.Fatalf("Error decoding %s hash: %v", name, err)
		}

		fmt.Printf("  Decoded format:\n")
		fmt.Printf("    Code: 0x%x (%s)\n", decoded.Code, decoded.Name)
		fmt.Printf("    Length: %d\n", decoded.Length)
		fmt.Printf("    Digest: %s\n\n", hex.EncodeToString(decoded.Digest))
	}

	// Generate a sha256 example in CIDv0 format (backward compatibility)
	mhSha256, err := mh.Sum(testData, mh.SHA2_256, -1)
	if err != nil {
		t.Fatal(err)
	}
	fmt.Printf("CIDv0 format (base58 with Qm prefix): Qm%s\n\n", mh.Multihash(mhSha256).B58String()[2:])

	// Generate S5 blob ID examples - properly using blake3.Sum256
	fmt.Printf("\n=== S5 Blob ID Examples ===\n\n")

	// Use Blake3 directly to hash the test data
	s5TestData := []byte("lume portal-plugin-abuse test data for S5")
	blake3Sum := blake3.Sum256(s5TestData)
	fmt.Printf("BLAKE3 hash of test data: %x\n", blake3Sum[:])

	// SHA256 hash for comparison
	stdSha256Sum := sha256.Sum256(s5TestData)
	stdSha256HashBytes := stdSha256Sum[:]
	fmt.Printf("SHA256 hash of test data: %x\n\n", stdSha256HashBytes)

	// Construct S5 blob IDs directly from binary data
	constructS5BlobID := func(hashFn byte, hashBytes []byte, size uint64) []byte {
		// Magic bytes: 0x5b (S5 Blob) + 0x82 (plaintext, unencrypted)
		magicBytes := []byte{0x5b, 0x82}

		// Create size bytes in little-endian format
		var sizeBuffer bytes.Buffer
		binary.Write(&sizeBuffer, binary.LittleEndian, size)
		sizeBytes := bytes.TrimRight(sizeBuffer.Bytes(), "\x00")

		// Combine all parts
		blobID := make([]byte, 0, len(magicBytes)+1+len(hashBytes)+len(sizeBytes))
		blobID = append(blobID, magicBytes...)
		blobID = append(blobID, hashFn)
		blobID = append(blobID, hashBytes...)
		blobID = append(blobID, sizeBytes...)

		return blobID
	}

	// Create S5 Blob IDs with different sizes
	s5BlobSmall := constructS5BlobID(0x1e, blake3Sum[:], 42)         // BLAKE3, small file
	s5BlobMedium := constructS5BlobID(0x1e, blake3Sum[:], 32768)     // BLAKE3, medium file (32 KiB)
	s5BlobSha256 := constructS5BlobID(0x12, stdSha256HashBytes, 100) // SHA256, small file
	s5BlobLarge := constructS5BlobID(0x1e, blake3Sum[:], 134217728)  // BLAKE3, large file (128 MiB)

	// Print hex encodings
	fmt.Printf("S5 Blob ID (hex - small file with BLAKE3): %x\n", s5BlobSmall)
	fmt.Printf("S5 Blob ID (hex - medium file with BLAKE3): %x\n", s5BlobMedium)
	fmt.Printf("S5 Blob ID (hex - small file with SHA256): %x\n", s5BlobSha256)
	fmt.Printf("S5 Blob ID (hex - large file with BLAKE3): %x\n", s5BlobLarge)

	// Create other encodings
	fmt.Printf("\nS5 Blob ID (base64url - small file): %s\n", base64.URLEncoding.EncodeToString(s5BlobSmall))
	fmt.Printf("S5 Blob ID (base32 - medium file): %s\n", base32.StdEncoding.EncodeToString(s5BlobMedium))
	fmt.Printf("S5 Blob ID (base58 - large file): %s\n\n", base58.Encode(s5BlobLarge))

	// Recommended regex pattern
	fmt.Printf("Recommended regex pattern for matching multihashes and S5 Blob IDs:\n")
	fmt.Printf("`(Qm[1-9A-HJ-NP-Za-km-z]{44}|bafy[a-zA-Z0-9]{55}|z[a-zA-Z0-9]{48,}|k[a-zA-Z0-9]{46,}|[1-9A-HJ-NP-Za-km-z]{43,}|[0-9][a-zA-Z0-9]{40,}|[0-9a-fA-F]{64}|5b82(1e|12)[0-9a-fA-F]{66,80})`\n\n")

	fmt.Printf("This pattern matches:\n")
	fmt.Printf("- CIDv0: Qm prefix with 44 base58 chars\n")
	fmt.Printf("- CIDv1 base32: bafy prefix (base32)\n")
	fmt.Printf("- CIDv1 base58: z prefix\n")
	fmt.Printf("- Base36 CIDs: k prefix\n")
	fmt.Printf("- Raw base58 multihash: base58 chars\n")
	fmt.Printf("- Multihash with digit prefix\n")
	fmt.Printf("- Hex format hashes: 64 hex chars\n")
	fmt.Printf("- S5 Blob IDs: 5b82 magic bytes followed by hash function (1e/12) and hash+size\n")
}
